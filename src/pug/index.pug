extends base.pug

block vars
    - var title = "";

block navlinks
    li.nav-item
        a.nav-link.me-lg-3(href='#features') Features
    li.nav-item
        a.nav-link.me-lg-3(href='#download') Download

block content
    // Mashead header
    header.masthead
        .container.px-5
            .row.gx-5.align-items-center
                .col-lg-6
                    // Mashead text and app badges
                    .mb-5.mb-lg-0.text-center.text-lg-start
                        h1.display-1.lh-1.mb-3 Easily view your TreasuryDirect® account.
                        p.lead.fw-normal.text-muted.mb-5 This app is not affiliated with the US Government or TreasuryDirect® 
                        .d-flex.flex-column.flex-lg-row.align-items-center
                            a.me-lg-3.mb-4.mb-lg-0(href='#!')
                                img.app-badge(src='assets/img/google-play-badge.svg', alt='...')
                            a(href='#!')
                                img.app-badge(src='assets/img/app-store-badge.svg', alt='...')
                .col-lg-6
                    // Masthead device mockup feature
                    .masthead-device-mockup
                        include includes/gradient-circle
                        include includes/shape-1
                        include includes/shape-2
                        .device-wrapper
                            .device(data-device='iPhoneX', data-orientation='portrait', data-color='black')
                                .screen.bg-black
                                    // PUT CONTENTS HERE:
                                    // * * This can be a video, image, or just about anything else.
                                    // * * Set the max width of your media to 100% and the height to
                                    // * * 100% like the demo example below.
                                    video(muted='muted', autoplay='', loop='', style='max-width: 100%; height: 100%;')
                                        source(src='assets/img/appvid4.mp4', type='video/mp4')

    // Quote/testimonial aside
    aside.text-center.bg-gradient-primary-to-secondary
        .container.px-5
            .row.gx-5.justify-content-center
                .col-xl-8
                    .h2.fs-1.text-white.mb-4 We all know how frustrating TreasuryDirect® is to use.
                    // p.h4.fw-bold.text-white.mb-4.mb-lg-0 No more virtual keyboards for your password!
                    // img(src='assets/img/tnw-logo.svg', alt='...', style='height: 3rem;')

    // App features section
    section#features
        .container.px-5
            .row.gx-5.align-items-center
                .col-lg-8.order-lg-1.mb-5.mb-lg-0
                    .container-fluid.px-5
                        .row.gx-5
                            .col-md-6.mb-5
                                // Feature item
                                .text-center
                                    i.bi-patch-check.icon-feature.text-gradient.d-block.mb-3
                                    h3.font-alt Easy to Use
                                    p.text-muted.mb-0 The app logs in for you. No more virtual keyboards or buggy back buttons! 
                            .col-md-6.mb-5
                                // Feature item
                                .text-center
                                    i.bi-lock.icon-feature.text-gradient.d-block.mb-3
                                    h3.font-alt Safe and Secure
                                    p.text-muted.mb-0 Your login info stays on your phone and the app is protected by fingerprint/pin/faceid!
                        .row
                            .col-md-6.mb-5.mb-md-0
                                // Feature item
                                .text-center
                                    i.bi-cash-coin.icon-feature.text-gradient.d-block.mb-3
                                    h3.font-alt Stay Informed
                                    p.text-muted.mb-0 We make it easy to see all the detailed data from your account so you can make better financial decisions.
                            .col-md-6
                                // Feature item
                                .text-center
                                    i.bi-calculator.icon-feature.text-gradient.d-block.mb-3
                                    h3.font-alt Better Statistics
                                    p.text-muted.mb-0 We automatically calculate stats and figures about your securities for you.
                .col-lg-4.order-lg-0
                    // Features section device mockup
                    .features-device-mockup
                        include includes/gradient-circle
                        include includes/shape-1
                        include includes/shape-2
                        .device-wrapper
                            .device(data-device='iPhoneX', data-orientation='portrait', data-color='black')
                                .screen.bg-black
                                    // PUT CONTENTS HERE:
                                    // * * This can be a video, image, or just about anything else.
                                    // * * Set the max width of your media to 100% and the height to
                                    // * * 100% like the demo example below.
                                    img(src='assets/img/demo-login.png', style='max-width: 100%; height: 100%;')

    // Basic features section
    section.bg-light
        .container.px-5
            .row.gx-5.align-items-center.justify-content-center.justify-content-lg-between
                .col-12.col-lg-5
                    h2.display-4.lh-1.mb-4 Feature Roadmap:
                    div.lead.fw-normal.text-muted.mb-5.mb-lg-0
                        p Tell us which features you are interested in!
                        ul
                            li More advanced portfolio statistics
                            li Buy and sell Series I and Series EE Bonds
                            li View and manage order history
                            li Buy and sell Marketable Securities
                            li Portfolio performance graph
                            li Redeem securities
                            li Manage linked bank accounts
                .col-sm-8.col-md-6
                    .px-5.px-sm-0
                        img.img-fluid.rounded-circle(src='https://source.unsplash.com/u8Jn2rzYIps/900x900', alt='...')

    // Call to action section
    section.cta
        .cta-content
            .container.px-5
                h2.text-white.display-1.lh-1.mb-4
                    | Stop waiting.
                    br
                    | Start investing.
                a.btn.btn-outline-light.py-3.px-4.rounded-pill(id='download-button', href='#', target='_blank') Download Now

    // App badge section
    section#download.bg-gradient-primary-to-secondary
        .container.px-5
            h2.text-center.text-white.font-alt.mb-4 Get the app now!
            .d-flex.flex-column.flex-lg-row.align-items-center.justify-content-center
                a.me-lg-3.mb-4.mb-lg-0(href='#!')
                    img.app-badge(src='assets/img/google-play-badge.svg', alt='...')
                a(href='#!')
                    img.app-badge(src='assets/img/app-store-badge.svg', alt='...')

